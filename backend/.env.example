# Copy to .env and fill in values — never commit .env
NODE_ENV=development
PORT=3000

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET_64_BYTES
JWT_EXPIRES_IN=15m

# bcrypt cost factor (10-12 recommended for prod)
BCRYPT_ROUNDS=12

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/jobryx"

# Used by docker-compose to inject the DB password
DB_PASSWORD=CHANGE_ME

# WeLoveDevs API key — request at https://epi-api.welovedevs.com/ask-for-api-key/
WELOVEDEVS_API_KEY=
